# API Configuration (Supports any OpenAI-compatible API)
OPENAI_API_KEY=your_api_key_here

# Optional: Set a custom base URL if using a custom endpoint or another model provider (like DeepSeek, Ollama, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Specify the model name
# OPENAI_MODEL=gpt-4o

# --- Backward compatibility with DeepSeek ---
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
